        <div id="calculatorBody" style="display:none;">
            <div class="row">
                <div class="col"><label>Пол</label><select id="calcGender"><option value="male">Мужской</option><option value="female">Женский</option></select></div>
                <div class="col"><label>Вес (кг)</label><input type="number" id="calcWeight" value="70" min="20"></div>
                <div class="col"><label>Рост (см)</label><input type="number" id="calcHeight" value="170" min="100"></div>
                <div class="col"><label>Возраст</label><input type="number" id="calcAge" value="25" min="10"></div>
            </div>
            <div class="row" style="margin-top:8px;">
                <div class="col"><label>Активность</label>
                    <select id="calcActivity">
                        <option value="1.2">Сидячий образ жизни</option>
                        <option value="1.375">Лёгкая активность (1-3 р/нед)</option>
                        <option value="1.55">Средняя (3-5 р/нед)</option>
                        <option value="1.725">Высокая (6-7 р/нед)</option>
                        <option value="1.9">Экстремальная</option>
                    </select>
                </div>
            </div>
            <button style="margin-top:10px;" onclick="calculateNorm()">Рассчитать</button>
            <div id="calcResult" style="margin-top:10px;"></div>
        </div>
    </div>

    <!-- Добавление своего продукта (внизу) -->
    <div class="card">
        <div class="card-title" style="cursor:pointer;" onclick="document.getElementById('customProductForm').style.display = document.getElementById('customProductForm').style.display === 'none' ? 'block' : 'none'">➕ Добавить свой продукт ▾</div>
