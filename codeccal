            ["Цельнозерновой",247,8.8,3.4,41.3,"кусок",30],
            ["Батон",263,7.5,3.1,51.0,"кусок",25],
            ["Лаваш",277,9.1,1.1,56.0,"лист",70],
            ["Овсяное печенье",437,6.5,14.5,71.0,"шт",15],
            ["Крекер",420,8.0,14.0,67.0,"шт",10],
            // Орехи и сухофрукты
            ["Грецкий орех",654,15.2,65.2,13.7,"г",0],
            ["Миндаль",575,21.2,49.4,21.6,"г",0],
            ["Арахис",567,26.0,49.0,16.1,"г",0],
            ["Фундук",628,15.0,60.8,16.7,"г",0],
            ["Кешью",553,18.2,43.8,30.2,"г",0],
            ["Изюм",299,3.1,0.5,79.2,"г",0],
            ["Курага",241,3.4,0.5,62.6,"г",0],
            ["Чернослив",256,2.3,0.7,57.5,"шт",10],
            ["Финики",282,2.5,0.5,75.0,"шт",10],
            // Ингушская кухня
            ["Чапилг с творогом",220,10.0,9.0,24.0,"шт",150],
            ["Чапилг с картошкой",200,5.0,8.0,27.0,"шт",150],
            ["Чапилг с тыквой",185,5.0,7.0,25.0,"шт",150],
            ["Сискал (кукур. лепёшка)",175,5.6,5.6,23.9,"шт",100],
            ["Халтам (галушки)",180,6.0,2.0,35.0,"г",0]
        ];

        // Загружаем кастомные продукты
        const savedCustom = JSON.parse(localStorage.getItem('customProducts') || '[]');
        PRODUCTS = PRODUCTS.concat(savedCustom);

        // ========== СОСТОЯНИЕ ==========
        let currentDate = new Date().toISOString().split('T')[0];
        let dailyGoal = parseInt(localStorage.getItem('calorieGoal')) || 2000;
        let waterGoal = parseInt(localStorage.getItem('waterGoal')) || 2000;
        let selectedProduct = null;
        let favorites = JSON.parse(localStorage.getItem('favorites') || '[]');
        let searchHistory = JSON.parse(localStorage.getItem('searchHistory') || '[]');

        function getKey(date, type) { return type + '_' + date; }
        function getDayData(date, type) { return JSON.parse(localStorage.getItem(getKey(date, type)) || '[]'); }
        function saveDayData(date, type, data) { localStorage.setItem(getKey(date, type), JSON.stringify(data)); }

        // Тема
        function toggleTheme() {
            document.body.classList.toggle('dark');
            localStorage.setItem('theme', document.body.classList.contains('dark') ? 'dark' : 'light');
        }
        if (localStorage.getItem('theme') === 'dark') document.body.classList.add('dark');

        // Калькулятор нормы
        function toggleCalculator() {
            const body = document.getElementById('calculatorBody');
            body.style.display = body.style.display === 'none' ? 'block' : 'none';
        }
        function calculateNorm() {
            const gender = document.getElementById('calcGender').value;
            const weight = parseFloat(document.getElementById('calcWeight').value);
            const height = parseFloat(document.getElementById('calcHeight').value);
            const age = parseInt(document.getElementById('calcAge').value);
            const activity = parseFloat(document.getElementById('calcActivity').value);
            let bmr;
            if (gender === 'male') {
                bmr = 10 * weight + 6.25 * height - 5 * age + 5;
            } else {
                bmr = 10 * weight + 6.25 * height - 5 * age - 161;
            }
            const calories = Math.round(bmr * activity);
            const water = Math.round(weight * 35);
            document.getElementById('calcResult').innerHTML = `
                <div>Рекомендуемая норма: <strong>${calories} ккал</strong> в день</div>
                <div>Воды: <strong>${water} мл</strong> в день</div>
                <button class="small" onclick="applyNorms(${calories}, ${water})">Применить</button>
            `;
        }
        function applyNorms(cal, water) {
            dailyGoal = cal;
            waterGoal = water;
            localStorage.setItem('calorieGoal', dailyGoal);
            localStorage.setItem('waterGoal', waterGoal);
            document.getElementById('goalInput').value = dailyGoal;
            document.getElementById('waterGoal').value = waterGoal;
            renderDiary();
            renderWater();
        }

        // Поиск с историей и избранным
        const searchInput = document.getElementById('searchInput');
        const dropdown = document.getElementById('dropdown');
        let selectedIndex = -1;

        searchInput.addEventListener('input', function() {
            const query = this.value.trim().toLowerCase();
            dropdown.innerHTML = '';
            selectedIndex = -1;
            if (query.length < 1) {
                dropdown.classList.remove('active');
                return;
            }
            const filtered = PRODUCTS.filter(p => p[0].toLowerCase().includes(query)).slice(0, 15);
            if (filtered.length === 0) {
                dropdown.innerHTML = '<div style="padding:16px;text-align:center;opacity:0.6;">Ничего не найдено</div>';
            } else {
                filtered.forEach((product, idx) => {
                    const div = document.createElement('div');
                    div.className = 'dropdown-item';
                    const regex = new RegExp(`(${query.replace(/[.*+?^${}()|[\]\\]/g,'\\$&')})`, 'gi');
                    const highlightedName = product[0].replace(regex, '<mark style="background:var(--accent-light);color:var(--accent);padding:0 2px;border-radius:3px;">$1</mark>');
                    const unit = product[5];
                    const weight = product[6];
                    let unitStr = '';
                    if (unit !== 'г' && weight > 0) unitStr = ` (1 ${unit} ≈ ${weight} г)`;
                    div.innerHTML = `
                        <div>
                            <div style="font-weight:500;">${highlightedName} ${unitStr} ${favorites.includes(product[0]) ? '⭐' : ''}</div>
                            <div style="font-size:12px;opacity:0.7;">Б:${product[2]} Ж:${product[3]} У:${product[4]}</div>
                        </div>
                        <div style="font-weight:600;color:var(--accent);">${product[1]} ккал</div>
                    `;
                    div.addEventListener('click', () => {
                        selectProduct(product);
                        addToHistory(product[0]);
                        dropdown.classList.remove('active');
                    });
                    dropdown.appendChild(div);
                });
            }
            dropdown.classList.add('active');
        });

        searchInput.addEventListener('keydown', function(e) {
            const items = dropdown.querySelectorAll('.dropdown-item');
            if (!dropdown.classList.contains('active') || items.length === 0) return;
            if (e.key === 'ArrowDown') {
                e.preventDefault();
                selectedIndex = Math.min(selectedIndex + 1, items.length - 1);
                updateSelection(items);
            } else if (e.key === 'ArrowUp') {
                e.preventDefault();
                selectedIndex = Math.max(selectedIndex - 1, 0);
                updateSelection(items);
            } else if (e.key === 'Enter' && selectedIndex >= 0) {
                e.preventDefault();
                items[selectedIndex].click();
            }
        });

        function updateSelection(items) {
            items.forEach((item, i) => {
                item.classList.toggle('selected', i === selectedIndex);
                if (i === selectedIndex) item.scrollIntoView({ block: 'nearest' });
            });
        }

        document.addEventListener('click', (e) => {
            if (!e.target.closest('.search-wrapper')) dropdown.classList.remove('active');
        });

        function addToHistory(term) {
            searchHistory = [term, ...searchHistory.filter(t => t !== term)].slice(0, 10);
            localStorage.setItem('searchHistory', JSON.stringify(searchHistory));
        }
        function showHistory(e) {
            e.preventDefault();
            dropdown.innerHTML = searchHistory.length ? searchHistory.map(term => `<div class="dropdown-item" onclick="searchInput.value='${term}'; searchInput.dispatchEvent(new Event('input')); dropdown.classList.remove('active');">🕒 ${term}</div>`).join('') : '<div style="padding:10px;">Пусто</div>';
            dropdown.classList.add('active');
        }
        function showFavorites(e) {
            e.preventDefault();
            const favProducts = PRODUCTS.filter(p => favorites.includes(p[0]));
            dropdown.innerHTML = favProducts.length ? favProducts.map(p => `<div class="dropdown-item" onclick="selectProduct(${JSON.stringify(p).replace(/"/g, '&quot;')}); dropdown.classList.remove('active');">⭐ ${p[0]} (${p[1]} ккал)</div>`).join('') : '<div style="padding:10px;">Нет избранного</div>';
            dropdown.classList.add('active');
        }

        function selectProduct(product) {
            selectedProduct = product;
            document.getElementById('selectedProduct').value = product[0];
            document.getElementById('previewName').textContent = product[0];
            document.getElementById('previewKcal').textContent = product[1];
            document.getElementById('previewProtein').textContent = product[2];
            document.getElementById('previewFat').textContent = product[3];
            document.getElementById('previewCarbs').textContent = product[4];
            const unit = product[5], weight = product[6];
            const unitInfo = document.getElementById('previewUnitInfo');
            if (unit !== 'г' && weight > 0) {
                unitInfo.textContent = `📏 1 ${unit} ≈ ${weight} г`;
                document.getElementById('quantityLabel').textContent = unit.charAt(0).toUpperCase() + unit.slice(1);
                document.getElementById('quantityInput').value = 1;
            } else {
                unitInfo.textContent = '';
                document.getElementById('quantityLabel').textContent = 'Граммы';
                document.getElementById('quantityInput').value = 100;
            }
            document.getElementById('productPreview').classList.add('active');
            document.getElementById('favBtn').textContent = favorites.includes(product[0]) ? '⭐' : '☆';
            searchInput.value = product[0];
        }

        function toggleFavorite() {
            if (!selectedProduct) return;
            const name = selectedProduct[0];
            if (favorites.includes(name)) {
                favorites = favorites.filter(f => f !== name);
            } else {
                favorites.push(name);
            }
            localStorage.setItem('favorites', JSON.stringify(favorites));
            document.getElementById('favBtn').textContent = favorites.includes(name) ? '⭐' : '☆';
        }

        // Свой продукт
        function addCustomProduct() {
            const name = document.getElementById('customName').value.trim();
            const kcal = parseFloat(document.getElementById('customKcal').value);
            const protein = parseFloat(document.getElementById('customProtein').value);
            const fat = parseFloat(document.getElementById('customFat').value);
            const carbs = parseFloat(document.getElementById('customCarbs').value);
            if (!name) return alert('Введите название');
            const product = [name, kcal, protein, fat, carbs, 'г', 0];
            PRODUCTS.push(product);
            const custom = JSON.parse(localStorage.getItem('customProducts') || '[]');
            custom.push(product);
            localStorage.setItem('customProducts', JSON.stringify(custom));
            document.getElementById('customName').value = '';
            document.getElementById('customKcal').value = 0;
            alert('Продукт добавлен!');
        }

        // Конструктор блюд
        function addComponentRow() {
            const container = document.getElementById('mealComponents');
            const row = document.createElement('div');
            row.className = 'row';
            row.innerHTML = `
                <div class="col"><input type="text" placeholder="Продукт" class="comp-search"></div>
                <div class="col" style="max-width:100px;"><input type="number" placeholder="Вес (г)" value="100"></div>
                <button class="small danger" onclick="this.parentElement.remove()">✕</button>
            `;
            container.appendChild(row);
        }
        function createMeal() {
            const mealName = document.getElementById('mealName').value.trim();
            const totalWeight = parseFloat(document.getElementById('mealTotalWeight').value);
            if (!mealName || !totalWeight) return alert('Введите название и вес блюда');
            const rows = document.querySelectorAll('#mealComponents .row');
            let totalKcal = 0, totalP = 0, totalF = 0, totalC = 0;
            for (const row of rows) {
                const input = row.querySelector('.comp-search');
                const weightInput = row.querySelector('input[type="number"]');
                const name = input.value.trim();
                const weight = parseFloat(weightInput.value);
                const product = PRODUCTS.find(p => p[0].toLowerCase() === name.toLowerCase());
                if (!product || !weight) continue;
                const [_, kcal100, p100, f100, c100] = product;
                totalKcal += kcal100 * weight / 100;
                totalP += p100 * weight / 100;
                totalF += f100 * weight / 100;
                totalC += c100 * weight / 100;
            }
            const per100Kcal = Math.round(totalKcal / totalWeight * 100);
            const per100P = +(totalP / totalWeight * 100).toFixed(1);
            const per100F = +(totalF / totalWeight * 100).toFixed(1);
            const per100C = +(totalC / totalWeight * 100).toFixed(1);
            const newMeal = [mealName, per100Kcal, per100P, per100F, per100C, 'г', 0];
            PRODUCTS.push(newMeal);
            const custom = JSON.parse(localStorage.getItem('customProducts') || '[]');
            custom.push(newMeal);
            localStorage.setItem('customProducts', JSON.stringify(custom));
            selectedProduct = newMeal;
            document.getElementById('selectedProduct').value = newMeal[0];
            alert(`Блюдо "${mealName}" создано! Можно добавить в дневник.`);
        }

        // Вода
        function addWater() {
            const amount = parseFloat(document.getElementById('waterInput').value);
            if (!amount || amount <= 0) return;
            const data = getDayData(currentDate, 'water');
            data.push(amount);
            saveDayData(currentDate, 'water', data);
            document.getElementById('waterInput').value = 250;
            renderWater();
        }
        function clearWater() {
            if (confirm('Очистить всю выпитую воду за этот день?')) {
                saveDayData(currentDate, 'water', []);
                renderWater();
            }
        }
        function renderWater() {
            const data = getDayData(currentDate, 'water');
            const total = data.reduce((s, v) => s + v, 0);
            document.getElementById('waterDrank').textContent = total;
            const percent = waterGoal > 0 ? Math.min((total / waterGoal) * 100, 100) : 0;
            document.getElementById('waterFill').style.width = percent + '%';
            document.getElementById('waterGoal').value = waterGoal;
        }
        function updateWaterGoal() {
            waterGoal = parseInt(document.getElementById('waterGoal').value) || 2000;
            localStorage.setItem('waterGoal', waterGoal);
            renderWater();
        }

        // Дневник
        function addToDiary() {
            if (!selectedProduct) return alert('Сначала выберите продукт');
            const quantity = parseFloat(document.getElementById('quantityInput').value);
            if (!quantity || quantity <= 0) return alert('Введите количество');
            const meal = document.getElementById('mealSelect').value;
            const [name, kcal100, p100, f100, c100, unit, weightPerUnit] = selectedProduct;
            let grams;
            if (unit !== 'г' && weightPerUnit > 0) grams = quantity * weightPerUnit;
            else grams = quantity;
            const item = {
                name,
                quantity: quantity + (unit !== 'г' ? ' ' + unit : ' г'),
                grams: +grams.toFixed(1),
                kcal: Math.round(kcal100 * grams / 100),
                protein: +(p100 * grams / 100).toFixed(1),
                fat: +(f100 * grams / 100).toFixed(1),
                carbs: +(c100 * grams / 100).toFixed(1),
                meal,
                time: new Date().toLocaleTimeString([], {hour:'2-digit', minute:'2-digit'})
            };
            const data = getDayData(currentDate, 'diary');
            data.push(item);
            saveDayData(currentDate, 'diary', data);
            document.getElementById('quantityInput').value = (unit !== 'г' ? 1 : 100);
            renderDiary();
        }
        function deleteItem(index) {
            const data = getDayData(currentDate, 'diary');
            data.splice(index, 1);
            saveDayData(currentDate, 'diary', data);
            renderDiary();
        }
        function clearDiary() {
            if (confirm('Удалить все записи за этот день?')) {
                saveDayData(currentDate, 'diary', []);
                renderDiary();
            }
        }
        function renderDiary() {
            document.getElementById('dateDisplay').textContent = formatDate(currentDate);
            const data = getDayData(currentDate, 'diary');
            const container = document.getElementById('diaryContent');
            if (data.length === 0) {
                container.innerHTML = '<div style="text-align:center; opacity:0.5; padding:20px;">Пока пусто</div>';
            } else {
                let html = `<table><thead><tr><th>Продукт</th><th>Кол-во</th><th>Вес</th><th>Приём</th><th>Ккал</th><th>Б</th><th>Ж</th><th>У</th><th></th></tr></thead><tbody>`;
                const mealNames = {breakfast:'Завтрак', lunch:'Обед', dinner:'Ужин', snack:'Перекус'};
                const mealColors = {breakfast:'#fbbf24', lunch:'#f87171', dinner:'#818cf8', snack:'#34d399'};
                data.forEach((item, i) => {
                    const badge = mealColors[item.meal] || '#ccc';
                    html += `<tr>
                        <td>${item.name}</td>
                        <td>${item.quantity}</td>
                        <td>${item.grams} г</td>
                        <td><span style="display:inline-block;width:8px;height:8px;border-radius:50%;background:${badge};margin-right:6px;"></span>${mealNames[item.meal]||item.meal}</td>
                        <td>${item.kcal}</td>
                        <td>${item.protein}</td>
                        <td>${item.fat}</td>
                        <td>${item.carbs}</td>
                        <td><button class="small danger" onclick="deleteItem(${i})" style="padding:4px 8px;">✕</button></td>
                    </tr>`;
                });
                html += '</tbody></table>';
                container.innerHTML = html;
            }
            updateStats(data);
        }
        function updateStats(data) {
            const totalKcal = data.reduce((s,i) => s + i.kcal, 0);
            const totalP = data.reduce((s,i) => s + i.protein, 0);
            const totalF = data.reduce((s,i) => s + i.fat, 0);
            const totalC = data.reduce((s,i) => s + i.carbs, 0);
            document.getElementById('totalKcal').textContent = totalKcal;
            document.getElementById('totalProtein').textContent = totalP.toFixed(1);
            document.getElementById('totalFat').textContent = totalF.toFixed(1);
            document.getElementById('totalCarbs').textContent = totalC.toFixed(1);
            document.getElementById('eatenKcal').textContent = totalKcal;
            const percent = dailyGoal > 0 ? Math.min((totalKcal / dailyGoal) * 100, 100) : 0;
            const fill = document.getElementById('progressFill');
            fill.style.width = percent + '%';
            fill.className = 'progress-fill ' + (percent >= 100 ? 'over' : percent >= 85 ? 'warning' : '');
            const left = dailyGoal - totalKcal;
            const leftSpan = document.getElementById('leftKcal');
            leftSpan.textContent = left > 0 ? `Осталось: ${left} ккал` : `Перебор на ${Math.abs(left)} ккал`;
            leftSpan.style.color = left >= 0 ? '' : 'var(--danger)';
            document.getElementById('goalInput').value = dailyGoal;
        }

        // Даты
        function formatDate(dateStr) {
            const [y,m,d] = dateStr.split('-');
            const months = ['Янв','Фев','Мар','Апр','Май','Июн','Июл','Авг','Сен','Окт','Ноя','Дек'];
            return `${d} ${months[parseInt(m)-1]} ${y}`;
        }
        function changeDate(delta) {
            const d = new Date(currentDate);
            d.setDate(d.getDate() + delta);
            currentDate = d.toISOString().split('T')[0];
            renderDiary();
            renderWater();
        }
        function goToToday() {
            currentDate = new Date().toISOString().split('T')[0];
            renderDiary();
            renderWater();
        }
        function updateGoal() {
            dailyGoal = parseInt(document.getElementById('goalInput').value) || 2000;
            localStorage.setItem('calorieGoal', dailyGoal);
            renderDiary();
        }

        // Экспорт CSV
        function exportCSV() {
            const data = getDayData(currentDate, 'diary');
            let csv = 'Продукт,Количество,Вес (г),Приём,Ккал,Белки,Жиры,Углеводы\n';
            const mealNames = {breakfast:'Завтрак', lunch:'Обед', dinner:'Ужин', snack:'Перекус'};
            data.forEach(i => {
                csv += `"${i.name}","${i.quantity}",${i.grams},${mealNames[i.meal]||i.meal},${i.kcal},${i.protein},${i.fat},${i.carbs}\n`;
            });
            const blob = new Blob([csv], {type:'text/csv'});
            const a = document.createElement('a');
            a.href = URL.createObjectURL(blob);
            a.download = `калории_${currentDate}.csv`;
            a.click();
        }

        // Старт
        document.getElementById('dateDisplay').textContent = formatDate(currentDate);
        renderDiary();
        renderWater();
    </script>
</body>
</html>
