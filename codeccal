</h1>
        <div style="display: flex; gap: 6px; align-items: center;">
            <button class="small outline" onclick="changeDate(-1)">◀ Вчера</button>
            <button class="small" onclick="goToToday()">Сегодня</button>
            <button class="small outline" onclick="changeDate(1)">Завтра ▶</button>
            <span id="dateDisplay" style="font-weight:500; margin-left: 8px;"></span>
            <button class="theme-btn" onclick="toggleTheme()">🌓</button>
        </div>
    </header>

    <!-- Поиск с историей и избранным -->
    <div class="card">
        <div class="card-title">🔍 Найти продукт 
            <span style="margin-left:auto; font-size:12px;">
                <a href="#" onclick="showFavorites(event)" style="color:var(--accent);">⭐ Избранное</a> | 
                <a href="#" onclick="showHistory(event)" style="color:var(--accent);">🕒 История</a>
            </span>
        </div>
        <div class="search-wrapper">
            <input type="text" id="searchInput" placeholder="Введите название продукта..." autocomplete="off">
            <div class="dropdown" id="dropdown"></div>
        </div>
        <div class="product-preview" id="productPreview">
            <div>
                <strong id="previewName"></strong>
                <div style="display:flex; gap:12px; margin-top:4px; font-size:13px; flex-wrap:wrap;">
                    <span>🔥 <span id="previewKcal"></span> ккал/100г</span>
                    <span>🍗 <span id="previewProtein"></span>г</span>
                    <span>🧈 <span id="previewFat"></span>г</span>
                    <span>🍞 <span id="previewCarbs"></span>г</span>
                    <span id="previewUnitInfo" style="opacity:0.8;"></span>
                </div>
            </div>
            <button class="small" onclick="toggleFavorite()" id="favBtn">⭐</button>
        </div>
    </div>

    <!-- Добавить в дневник -->
    <div class="card">
        <div class="card-title">➕ Добавить в дневник</div>
        <div class="row">
            <div class="col"><label>Продукт</label><input type="text" id="selectedProduct" readonly placeholder="Выберите из поиска"></div>
            <div class="col" style="max-width:130px;">
                <label id="quantityLabel">Граммы</label>
                <input type="number" id="quantityInput" value="100" min="0.1" step="0.1">
            </div>
            <div class="col" style="max-width:140px;"><label>Приём</label><select id="mealSelect"><option value="breakfast">Завтрак</option><option value="lunch">Обед</option><option value="dinner">Ужин</option><option value="snack">Перекус</option></select></div>
            <div class="col" style="max-width:100px; display:flex; align-items:end;"><button onclick="addToDiary()">Добавить</button></div>
        </div>
    </div>

    <!-- Вода -->
    <div class="card">
        <div class="card-title">💧 Вода</div>
        <div class="row">
            <div class="col"><input type="number" id="waterInput" placeholder="мл" min="0" value="250"></div>
            <div class="col" style="max-width:80px;"><button onclick="addWater()">+</button></div>
            <div class="col" style="flex:2; display:flex; align-items:center;">
                <span>Цель: <input type="number" id="waterGoal" value="2000" min="0" style="width:80px;" onchange="updateWaterGoal()"> мл</span>
                <button class="small danger" onclick="clearWater()" style="margin-left:10px;">🗑 Очистить</button>
            </div>
        </div>
        <div class="progress-bar" style="margin-top:8px;">
            <div class="progress-fill" id="waterFill" style="width:0%; background:#38bdf8;"></div>
        </div>
        <div style="font-size:13px; margin-top:4px;">Выпито: <strong id="waterDrank">0</strong> мл</div>
    </div>

    <!-- Прогресс калорий -->
    <div class="card">
        <div class="card-title">📈 Прогресс калорий</div>
        <div style="display:flex; gap:10px; align-items:center; flex-wrap:wrap;">
            <label style="margin:0;">Цель (ккал):</label>
            <input type="number" id="goalInput" value="2000" min="500" max="10000" style="width:100px;" onchange="updateGoal()">
        </div>
        <div class="progress-bar"><div class="progress-fill" id="progressFill" style="width:0%;"></div></div>
        <div style="display:flex; justify-content:space-between; margin-top:6px; font-size:13px;">
            <span>Съедено: <strong id="eatenKcal">0</strong> ккал</span>
            <span id="leftKcal" style="font-weight:600;">Осталось: 2000</span>
        </div>
        <div class="macros-grid">
            <div class="macro-card" style="color:var(--accent);"><div class="value" id="totalKcal">0</div><div class="label">Калории</div></div>
            <div class="macro-card" style="color:#ef4444;"><div class="value" id="totalProtein">0</div><div class="label">Белки (г)</div></div>
            <div class="macro-card" style="color:#f59e0b;"><div class="value" id="totalFat">0</div><div class="label">Жиры (г)</div></div>
            <div class="macro-card" style="color:#10b981;"><div class="value" id="totalCarbs">0</div><div class="label">Углеводы (г)</div></div>
        </div>
    </div>

    <!-- Дневник -->
    <div class="card">
        <div class="card-title" style="justify-content:space-between;">
            <span>📋 Дневник</span>
            <div style="display:flex; gap:6px;">
