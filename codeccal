<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Счётчик калорий + Вода + Блюда</title>
    <style>
        :root {
            --bg: #f0f2f5;
            --card: #fff;
            --text: #1a1a2e;
            --accent: #4f46e5;
            --accent-light: #eef2ff;
            --danger: #ef4444;
            --success: #10b981;
            --warning: #f59e0b;
            --border: #e5e7eb;
            --shadow: 0 1px 3px rgba(0,0,0,0.06);
            --radius: 12px;
        }
        .dark {
            --bg: #0f172a;
            --card: #1e293b;
            --text: #e2e8f0;
            --accent: #818cf8;
            --accent-light: #1e1b4b;
            --border: #334155;
            --shadow: 0 1px 3px rgba(0,0,0,0.3);
        }
        * { box-sizing: border-box; margin: 0; padding: 0; }
        body {
            font-family: 'Segoe UI', system-ui, sans-serif;
            background: var(--bg); color: var(--text);
            max-width: 900px; margin: 0 auto; padding: 16px;
            transition: background 0.3s, color 0.3s;
        }
        header { display: flex; justify-content: space-between; align-items: center; flex-wrap: wrap; gap: 10px; margin-bottom: 16px; }
        h1 { font-size: 22px; font-weight: 700; }
        .card {
            background: var(--card); border-radius: var(--radius);
            padding: 20px; margin-bottom: 14px;
            box-shadow: var(--shadow); border: 1px solid var(--border);
        }
        .card-title { font-size: 15px; font-weight: 600; margin-bottom: 12px; display: flex; align-items: center; gap: 8px; }
        .search-wrapper { position: relative; }
        .search-wrapper input {
            width: 100%; padding: 13px 16px; font-size: 15px;
            border: 2px solid var(--border); border-radius: 10px;
            background: var(--bg); color: var(--text); outline: none;
        }
        .search-wrapper input:focus { border-color: var(--accent); }
        .dropdown {
            position: absolute; top: 100%; left: 0; right: 0;
            background: var(--card); border: 1px solid var(--border);
            border-radius: 10px; max-height: 300px; overflow-y: auto;
            z-index: 100; display: none; box-shadow: 0 10px 25px rgba(0,0,0,0.15);
            margin-top: 4px;
        }
        .dropdown.active { display: block; }
        .dropdown-item {
            padding: 10px 16px; cursor: pointer;
            border-bottom: 1px solid var(--border);
            display: flex; justify-content: space-between; align-items: center;
        }
        .dropdown-item:last-child { border-bottom: none; }
        .dropdown-item:hover, .dropdown-item.selected { background: var(--accent-light); }
        .product-preview {
            display: flex; justify-content: space-between; align-items: center;
            padding: 12px 16px; background: var(--accent-light);
            border-radius: 10px; margin-top: 10px; display: none;
        }
        .product-preview.active { display: flex; }
        .row { display: flex; gap: 10px; flex-wrap: wrap; align-items: end; }
        .col { flex: 1; min-width: 100px; }
        label { display: block; font-size: 11px; font-weight: 600; margin-bottom: 4px; text-transform: uppercase; letter-spacing: 0.5px; opacity: 0.7; }
        input, select, button {
            width: 100%; padding: 11px 14px; border: 2px solid var(--border);
            border-radius: 10px; font-size: 14px; background: var(--bg);
            color: var(--text); font-family: inherit; outline: none;
        }
        input:focus, select:focus { border-color: var(--accent); }
        button {
            background: var(--accent); color: #fff; border: none;
            cursor: pointer; font-weight: 600; white-space: nowrap;
            transition: filter 0.2s, transform 0.1s;
        }
        button:hover { filter: brightness(1.1); }
        button:active { transform: scale(0.97); }
        button.danger { background: var(--danger); }
        button.small { width: auto; padding: 7px 12px; font-size: 12px; border-radius: 8px; }
        button.outline { background: transparent; border: 2px solid var(--accent); color: var(--accent); }
        table { width: 100%; border-collapse: collapse; font-size: 13px; }
        th { text-align: left; padding: 10px 8px; border-bottom: 2px solid var(--border); opacity: 0.7; font-size: 11px; }
        td { padding: 10px 8px; border-bottom: 1px solid var(--border); }
        .progress-bar { height: 16px; background: var(--border); border-radius: 10px; overflow: hidden; margin-top: 8px; }
        .progress-fill { height: 100%; border-radius: 10px; transition: width 0.5s; background: var(--success); }
        .progress-fill.warning { background: var(--warning); }
        .progress-fill.over { background: var(--danger); }
        .macros-grid { display: grid; grid-template-columns: repeat(4,1fr); gap: 10px; margin-top: 12px; text-align: center; }
        .macro-card { background: var(--bg); border-radius: 10px; padding: 12px 8px; }
        .macro-card .value { font-size: 22px; font-weight: 700; }
        .macro-card .label { font-size: 11px; opacity: 0.7; }
        .theme-btn {
            background: var(--card); border: 1px solid var(--border);
            border-radius: 50%; width: 40px; height: 40px; font-size: 18px;
            cursor: pointer; display: flex; align-items: center; justify-content: center;
        }
        @media (max-width: 600px) {
            .row { flex-direction: column; }
            .macros-grid { grid-template-columns: repeat(2,1fr); }
        }
    </style>
</head>
